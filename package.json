{
  "name": "cmd-ai",
  "version": "1.2.0",
  "description": "Natural language shell command generator and executor powered by AI",
  "bin": {
    "ai": "bin/ai.js"
  },
  "type": "module",
  "scripts": {
    "dev:check": "node --check bin/ai.js && node bin/ai.js --help > /dev/null",
    "dev:watch": "node scripts/dev-watch.mjs",
    "dev:link": "npm link",
    "dev:unlink": "npm unlink -g cmd-ai",
    "dev:pack": "npm pack --dry-run",
    "lint": "eslint ."
  },
  "keywords": [
    "cli",
    "openai",
    "terminal",
    "shell",
    "assistant",
    "cmd",
    "command-line",
    "bash",
    "zsh",
    "autocomplete"
  ],
  "author": {
    "email": "brodanoel@gmail.com",
    "name": "Broda Noel",
    "url": "https://github.com/BrodaNoel"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0"
  }
}
